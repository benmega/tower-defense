[flake8]
max-line-length = 100
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    venv,
    .eggs,
    *.egg,
    .pytest_cache,
    .mypy_cache,
    htmlcov,
    .claude,
ignore =
    E203,  # whitespace before ':'
    W503,  # line break before binary operator
    E501,  # line too long (handled by black)
extend-ignore = D100, D104, D101
per-file-ignores =
    __init__.py:F401, F403
    src/tests/*:D100,D101,D102,D103,D104,D105,D106,D107
max-complexity = 10
